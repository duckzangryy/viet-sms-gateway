# Vietnamese SMS API Configuration
NODE_ENV=development
PORT=3000

# Database
MONGODB_URI=mongodb://localhost:27017/viet_sms_api
REDIS_URL=redis://localhost:6379

# SMS Provider Configuration (Example - replace with actual providers)
# Viettel SMS API
VIETTEL_API_KEY=your_viettel_api_key
VIETTEL_API_SECRET=your_viettel_api_secret
VIETTEL_BRAND_NAME=YOUR_BRAND

# Mobifone SMS API
MOBIFONE_API_KEY=your_mobifone_api_key
MOBIFONE_API_SECRET=your_mobifone_api_secret

# Vinaphone SMS API
VINAPHONE_API_KEY=your_vinaphone_api_key
VINAPHONE_API_SECRET=your_vinaphone_api_secret

# International fallback (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Security
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=24h
BCRYPT_SALT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Payment
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_ACCESS_KEY=your_momo_access_key

# Pricing (in USD cents)
SMS_PRICE_PER_MESSAGE=1  # $0.01 per SMS
BULK_SMS_DISCOUNT=0.8    # 20% discount for bulk (1000+ messages)

# Monitoring
SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=info

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
